{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/blog/what-is-defi",
      "dest": "/blog-what-is-defi.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
